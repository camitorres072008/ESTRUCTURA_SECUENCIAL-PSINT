Algoritmo AREA_PERIMETRO
	Definir area, altura, perimetro, base Como Real
	Escribir "Introduce la base de un rectangulo:"
	Leer base
	Escribir " Introduce la altura del rectangulo:"
	leer altura
	area = base*altura
	perimetro = 2*(base+altura)
	Escribir " El area del rectangulo es: " area
	Escribir "El perimetrpo del rectangulo es " perimetro
FinAlgoritmo
