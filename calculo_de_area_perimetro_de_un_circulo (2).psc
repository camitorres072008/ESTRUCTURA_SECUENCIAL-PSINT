Algoritmo calculo_de_area_perimetro_de_un_circulo
	Escribir "hola te ayudaremos a calcular el perimetro y area de tu circulo"
	Definir area, perimetro, radio Como Real 
	p = 3.1416
	Escribir "Por favor introduce el radio de tu circulo (cm)"
	Leer radio
	area = p*radio^2
	perimetro = 2*p*radio
	Escribir "area:" area "(cm^2)"
	Escribir "perimetro:" perimetro "(cm)"
FinAlgoritmo
