Algoritmo numer_real_promedio
	Definir x, t , z, promedio Como Real
	Escribir " Introduzca el primer  numero real "
	leer x
	Escribir " Introduzca el segundo numero real"
	Leer t
	Escribir " Introduzca el tercer numero real"
	Leer z
	promedio = (x + t + z) /3
	Escribir " El promedio de los tres numeros es:" promedio

	
	
	
FinAlgoritmo
