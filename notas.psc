Algoritmo DefinitivaEstudiante
	Definir nota1, nota2, nota3, nota4 Como Real
	Imprimir ("ingrese la nota1 del estudiante: ")
	leer nota1
	Imprimir ("ingrese la nota2 del estudiante: ")
	leer nota2
	Imprimir ("ingrese la nota3 del estudiante: ")
	leer nota3
	Imprimir ("ingrese la nota4 del estudiante: ")
	leer nota4
	definitiva=(nota1+nota2+nota3+nota4)
	Imprimir "la definitiva es:", definitiva
FinAlgoritmo
