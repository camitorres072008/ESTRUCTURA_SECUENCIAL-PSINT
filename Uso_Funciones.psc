Algoritmo Uso_Funciones
	Definir   numer, seno, coseno, tangente, rais, logaritmo_n, logaritmo10 Como Real
	Escribir " ingrese un numero :"
	leer numer
	seno = sen(numer)
	coseno = cos(numer)
	tangente = tan(numer)
	rais = raiz( numer)
	logaritmo_n = ln( numer)
	logaritmo10 = ln(numer) / ln(10)
	
	
	
	
	
	
FinAlgoritmo
